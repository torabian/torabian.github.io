# This is the one we put in golang to server the websites.
VITE_REMOTE_SERVICE="/fireback-boilerplate/"
PUBLIC_URL="/fireback-boilerplate/"
VITE_PUBLIC_URL="/fireback-boilerplate/"
VITE_DEFAULT_ROUTE="/{locale}/dashboard"
TARGET_APP=fireback-boilerplate
